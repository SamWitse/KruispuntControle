procedure TForm1.PauzebuttonClick(Sender: TObject);
begin
  Kruispunt.pause
end;

procedure TForm1.StartButtonClick(Sender: TObject);
begin
  Kruispunt.Start ;
  OostWestAutoGenerator.Enabled := true ;
  NoordZuidAutoGenerator.Enabled := true ;
  ZuidNoordAutoGenerator.Enabled := true ;

end;

procedure TForm1.TppComboChange(Sender: TObject);
var
  tpplabel: string ;
begin
  tpplabel :=  TppCombo.items[TppCombo.ItemIndex] ;
  if tpplabel = 'Traag' then
    Kruispunt.MillisecondenPerTel := 1000
  else if tpplabel = 'Gemiddeld' then
    Kruispunt.MillisecondenPerTel := 500
  else
    Kruispunt.MillisecondenPerTel := 100
end;

end.
