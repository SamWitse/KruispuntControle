var
  Laag, Hoog, tpp: integer ;
  Auto: TAuto ;
  Reisweg: TReisweg ;
  baanvak: integer ;
begin
  tpp := RandomRange(2,5);
  Auto := TAuto.Create(clLime, tpp) ;
  baanvak := RandomRange (1,AantaloostWestbaanvakken + 1) ;
  Reisweg := TReisweg.Create(RouteOostWest[baanvak]) ;
